#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    char s[100]; // Declare a character array to store the input string
    scanf("%[^\n]%*c", s); // Read the input string until a newline character is encountered
                             // and discard the newline character itself.
    printf("Hello, World!\n"); // Print "Hello, World!" followed by a newline
    printf("%s\n", s);         // Print the input string 's' followed by a newline
    return 0;
}
